    {
      "cell_type": "markdown",
      "metadata": {
        "id": "context_text"
      },
      "source": [
        "## Contexto e Indicadores de Negocio Medibles (KPIs)\n",
        "ShopAnalytics S.A.S. requiere optimizar su inventario. Se han establecido las siguientes metas analíticas para los próximos 6 meses:\n",
        "\n",
        "1. **Reducción de Sobrestock:** Disminuir en un **15%** el exceso de stock de baja rotación.\n",
        "2. **Prevención de Stockouts:** Reducir un **20%** los quiebres de stock en artículos de alta demanda.\n",
        "3. **Rotación de Inventario:** Aumentar de **4 a 6 veces al año** la velocidad de salida del almacén.\n",
        "4. **Disponibilidad Regional:** Mantener stock clave sobre el **95%** en todas las regiones operativas.\n",
        "\n",
        "> **Nota sobre la simulación:** Los datos utilizados en esta demostración son generados sintéticamente mediante Python (`Pandas` / `NumPy`) para emular el comportamiento transaccional del e-commerce colombiano real (5,000 ventas y más de 10,000 ítems)."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "cell_imports"
      },
      "outputs": [],
      "source": [
        "# =========================================================\n",
        "# 0. CONFIGURACIÓN E IMPORTACIONES\n",
        "# =========================================================\n",
        "import pandas as pd\n",
        "import sqlite3\n",
        "import numpy as np\n",
        "import datetime\n",
        "import sys\n",
        "\n",
        "# Forzar codificación en entornos interactivos\n",
        "try:\n",
        "    if sys.stdout.encoding != 'utf-8':\n",
        "        sys.stdout.reconfigure(encoding='utf-8')\n",
        "except AttributeError:\n",
        "    pass\n",
        "\n",
        "print(\"[INFO] Librerías cargadas exitosamente.\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "cell_data_gen"
      },
      "outputs": [],
      "source": [
        "# =========================================================\n",
        "# 1. GENERACIÓN DE DATASET SIMULADO CON INVENTARIO ACTIVO\n",
        "# =========================================================\n",
        "print(\"[1/4] Generando dataset transaccional simulado...\")\n",
        "np.random.seed(42)\n",
        "num_ventas = 5000\n",
        "\n",
        "# Datos maestros\n",
        "ciudades_regiones = {\n",
        "    'Bogota': 'Andina', \n",
        "    'Medellin': 'Andina', \n",
        "    'Cali': 'Pacifica', \n",
        "    'Barranquilla': 'Caribe', \n",
        "    'Bucaramanga': 'Andina'\n",
        "}\n",
        "categorias_prods = {\n",
        "    'Tecnologia': ['Laptop ProBook', 'Smartphone X', 'Tablet Y'],\n",
        "    'Hogar': ['Cafetera', 'Licuadora', 'Aspiradora'],\n",
        "    'Moda': ['Chaqueta', 'Tenis Running', 'Camisa Algodon']\n",
        "}\n",
        "\n",
        "fechas = [datetime.date(2025, 1, 1) + datetime.timedelta(days=int(np.random.randint(0, 365))) for _ in range(num_ventas)]\n",
        "clientes_ids = [int(np.random.randint(1, 1001)) for _ in range(num_ventas)]\n",
        "ciudades_seleccionadas = np.random.choice(list(ciudades_regiones.keys()), num_ventas)\n",
        "\n",
        "# A. Clientes\n",
        "df_clientes = pd.DataFrame({\n",
        "    'cliente_id': range(1, 1001),\n",
        "    'nombre': [f\"Cliente_{i}\" for i in range(1, 1001)],\n",
        "    'segmento': np.random.choice(['Estandar', 'Premium', 'Nuevo'], 1000)\n",
        "})\n",
        "\n",
        "# B. Regiones\n",
        "df_regiones = pd.DataFrame({\n",
        "    'region_id': range(1, len(ciudades_regiones)+1),\n",
        "    'ciudad': list(ciudades_regiones.keys()),\n",
        "    'pais': 'Colombia'\n",
        "})\n",
        "dict_regiones = {ciudad: i+1 for i, ciudad in enumerate(ciudades_regiones.keys())}\n",
        "\n",
        "# C. Categorías y Productos con Columnas de Inventario\n",
        "lista_categorias = []\n",
        "lista_productos = []\n",
        "cat_id = 1\n",
        "prod_id = 1\n",
        "\n",
        "for cat, prods in categorias_prods.items():\n",
        "    lista_categorias.append({'categoria_id': cat_id, 'nombre_categoria': cat})\n",
        "    for p in prods:\n",
        "        stock_simulado = int(np.random.randint(5, 120))\n",
        "        punto_reorden_simulado = int(np.random.randint(15, 30))\n",
        "        lista_productos.append({\n",
        "            'producto_id': prod_id, \n",
        "            'nombre': p, \n",
        "            'precio_unitario': int(np.random.randint(50, 300) * 1000),\n",
        "            'categoria_id': cat_id,\n",
        "            'stock_actual': stock_simulado,\n",
        "            'punto_reorden': punto_reorden_simulado\n",
        "        })\n",
        "        prod_id += 1\n",
        "    cat_id += 1\n",
        "\n",
        "df_categorias = pd.DataFrame(lista_categorias)\n",
        "df_productos = pd.DataFrame(lista_productos)\n",
        "\n",
        "# D. Ventas y Detalles\n",
        "ventas_data = []\n",
        "detalles_data = []\n",
        "detalle_id_counter = 1\n",
        "\n",
        "for venta_id in range(1, num_ventas + 1):\n",
        "    cliente = np.random.choice(clientes_ids)\n",
        "    ciudad = ciudades_seleccionadas[venta_id - 1]\n",
        "    reg_id = dict_regiones[ciudad]\n",
        "\n",
        "    ventas_data.append({\n",
        "        'venta_id': venta_id, \n",
        "        'fecha_venta': fechas[venta_id-1], \n",
        "        'cliente_id': int(cliente), \n",
        "        'region_id': reg_id, \n",
        "        'total_venta': 0.0\n",
        "    })\n",
        "\n",
        "    num_items = np.random.randint(1, 4)\n",
        "    total_ticket = 0\n",
        "\n",
        "    for _ in range(num_items):\n",
        "        prod = df_productos.sample(1).iloc[0]\n",
        "        cantidad = int(np.random.randint(1, 5))\n",
        "        subtotal = int(prod['precio_unitario'] * cantidad)\n",
        "        total_ticket += subtotal\n",
        "\n",
        "        detalles_data.append({\n",
        "            'detalle_id': detalle_id_counter,\n",
        "            'venta_id': venta_id,\n",
        "            'producto_id': int(prod['producto_id']),\n",
        "            'cantidad': cantidad,\n",
        "            'subtotal': subtotal\n",
        "        })\n",
        "        detalle_id_counter += 1\n",
        "\n",
        "    ventas_data[-1]['total_venta'] = float(total_ticket)\n",
        "\n",
        "df_ventas = pd.DataFrame(ventas_data)\n",
        "df_detalles = pd.DataFrame(detalles_data)\n",
        "\n",
        "# Agregar producto ocioso/estancado (Legacy) para forzar alerta de overstock\n",
        "df_stagnant = pd.DataFrame([{\n",
        "    'producto_id': 10,\n",
        "    'nombre': 'Teclado Mecanico Retro',\n",
        "    'precio_unitario': 180000,\n",
        "    'categoria_id': 1,\n",
        "    'stock_actual': 95,\n",
        "    'punto_reorden': 15\n",
        "}])\n",
        "df_productos = pd.concat([df_productos, df_stagnant], ignore_index=True)\n",
        "\n",
        "print(f\"[OK] Dataset generado. {len(df_ventas)} ventas y {len(df_detalles)} items transaccionales.\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "cell_db_load"
      },
      "outputs": [],
      "source": [
        "# =========================================================\n",
        "# 2. INGESTA EN BASE DE DATOS LOCAL PORTABLE (SQLITE)\n",
        "# =========================================================\n",
        "print(\"[2/4] Creando conexion a shopanalytics.db e ingestando tablas...\")\n",
        "conn = sqlite3.connect('shopanalytics.db')\n",
        "\n",
        "df_clientes.to_sql('Clientes', conn, if_exists='replace', index=False)\n",
        "df_regiones.to_sql('Regiones', conn, if_exists='replace', index=False)\n",
        "df_categorias.to_sql('Categorias', conn, if_exists='replace', index=False)\n",
        "df_productos.to_sql('Productos', conn, if_exists='replace', index=False)\n",
        "df_ventas.to_sql('Ventas', conn, if_exists='replace', index=False)\n",
        "df_detalles.to_sql('Detalle_Ventas', conn, if_exists='replace', index=False)\n",
        "\n",
        "print(\"[OK] Base de datos creada exitosamente en SQLite.\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "cell_validations"
      },
      "outputs": [],
      "source": [
        "# =========================================================\n",
        "# 3. PRUEBAS DE CALIDAD E INTEGRIDAD DE DATOS\n",
        "# =========================================================\n",
        "print(\"[3/4] Iniciando rutinas automáticas de validación de calidad...\")\n",
        "errores_encontrados = 0\n",
        "\n",
        "# A. Conteo e Igualdad de Registros\n",
        "tablas_conteos = {\n",
        "    'Clientes': len(df_clientes),\n",
        "    'Regiones': len(df_regiones),\n",
        "    'Categorias': len(df_categorias),\n",
        "    'Productos': len(df_productos),\n",
        "    'Ventas': len(df_ventas),\n",
        "    'Detalle_Ventas': len(df_detalles)\n",
        "}\n",
        "\n",
        "print(\"  -> Verificando conteos:\")\n",
        "for tabla, expected in tablas_conteos.items():\n",
        "    db_count = pd.read_sql_query(f\"SELECT COUNT(*) as cant FROM {tabla}\", conn).iloc[0]['cant']\n",
        "    if db_count == expected:\n",
        "        print(f\"     [PASS] Tabla '{tabla}': {db_count} registros.\")\n",
        "    else:\n",
        "        print(f\"     [FAIL] Tabla '{tabla}': Error. Esperados {expected}, en BD {db_count}.\")\n",
        "        errores_encontrados += 1\n",
        "\n",
        "# B. Unicidad de Llaves Primarias\n",
        "print(\"  -> Verificando llaves primarias únicas:\")\n",
        "pks = {\n",
        "    'Clientes': 'cliente_id',\n",
        "    'Regiones': 'region_id',\n",
        "    'Categorias': 'categoria_id',\n",
        "    'Productos': 'producto_id',\n",
        "    'Ventas': 'venta_id',\n",
        "    'Detalle_Ventas': 'detalle_id'\n",
        "}\n",
        "for tabla, pk in pks.items():\n",
        "    dups = pd.read_sql_query(f\"SELECT COUNT({pk}) - COUNT(DISTINCT {pk}) as dups FROM {tabla}\", conn).iloc[0]['dups']\n",
        "    if dups == 0:\n",
        "        print(f"     [PASS] Llave '{pk}' de '{tabla}' es única.\")\n",
        "    else:\n",
        "        print(f"     [FAIL] Llave '{pk}' de '{tabla}' tiene duplicados.\")\n",
        "        errores_encontrados += 1\n",
        "\n",
        "# C. Consistencia Referencial\n",
        "print(\"  -> Verificando integridad referencial (huérfanos):\")\n",
        "h_cli = pd.read_sql_query(\"SELECT COUNT(v.venta_id) as cant FROM Ventas v LEFT JOIN Clientes c ON v.cliente_id = c.cliente_id WHERE c.cliente_id IS NULL\", conn).iloc[0]['cant']\n",
        "h_reg = pd.read_sql_query(\"SELECT COUNT(v.venta_id) as cant FROM Ventas v LEFT JOIN Regiones r ON v.region_id = r.region_id WHERE r.region_id IS NULL\", conn).iloc[0]['cant']\n",
        "h_det_v = pd.read_sql_query(\"SELECT COUNT(d.detalle_id) as cant FROM Detalle_Ventas d LEFT JOIN Ventas v ON d.venta_id = v.venta_id WHERE v.venta_id IS NULL\", conn).iloc[0]['cant']\n",
        "h_det_p = pd.read_sql_query(\"SELECT COUNT(d.detalle_id) as cant FROM Detalle_Ventas d LEFT JOIN Productos p ON d.producto_id = p.producto_id WHERE p.producto_id IS NULL\", conn).iloc[0]['cant']\n",
        "\n",
        "for label, val in [(\"Ventas -> Clientes\", h_cli), (\"Ventas -> Regiones\", h_reg), (\"Detalles -> Ventas\", h_det_v), (\"Detalles -> Productos\", h_det_p)]:\n",
        "    if val == 0:\n",
        "        print(f\"     [PASS] {label}: Integridad OK.\")\n",
        "    else:\n",
        "        print(f\"     [FAIL] {label}: Se encontraron {val} huérfanos.\")\n",
        "        errores_encontrados += 1\n",
        "\n",
        "if errores_encontrados == 0:\n",
        "    print(\"\\n[OK] Certificación de Calidad: Base de datos limpia al 100%.\")\n",
        "else:\n",
        "    print(f\"\\n[ALERTA] Se encontraron {errores_encontrados} inconsistencias en la validación.\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "query_intro"
      },
      "source": [
        "## 4. Consultas Analíticas del Negocio (Toma de Decisiones)\n",
        "Cada consulta SQL a continuación está diseñada para respaldar directamente una decisión directiva y actuar sobre las metas del negocio."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "query_a"
      },
      "outputs": [],
      "source": [
        "# --- CONSULTA A: Alerta Preventiva de Reabastecimiento ---\n",
        "# Decisión Directiva: Compra prioritaria de stock para evitar pérdidas por stockout.\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"[ANÁLISIS A] ALERTA DE REABASTECIMIENTO DE PRODUCTOS\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "query_reabast = '''\n",
        "    SELECT \n",
        "        p.producto_id,\n",
        "        p.nombre AS Producto,\n",
        "        c.nombre_categoria AS Categoria,\n",
        "        p.stock_actual AS Stock_Disponible,\n",
        "        p.punto_reorden AS Nivel_Seguridad,\n",
        "        (p.punto_reorden - p.stock_actual) AS Deficit_a_Pedir\n",
        "    FROM Productos p\n",
        "    JOIN Categorias c ON p.categoria_id = c.categoria_id\n",
        "    WHERE p.stock_actual <= p.punto_reorden\n",
        "    ORDER BY Deficit_a_Pedir DESC;\n",
        "'''\n",
        "df_reab = pd.read_sql_query(query_reabast, conn)\n",
        "df_reab"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "query_b"
      },
      "outputs": [],
      "source": [
        "# --- CONSULTA B: Alerta de Riesgo de Estancamiento y Sobrestock ---\n",
        "# Decisión Directiva: Liquidación comercial de inventario inmovilizado para agilizar el flujo de caja.\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"[ANÁLISIS B] ALERTA DE SOBRESTOCK / PRODUCTOS ESTANCADOS\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "query_overstock = '''\n",
        "    SELECT \n",
        "        p.nombre AS Producto,\n",
        "        p.stock_actual AS Stock_Almacenado,\n",
        "        COALESCE(SUM(d.cantidad), 0) AS Unidades_Vendidas,\n",
        "        (p.stock_actual - COALESCE(SUM(d.cantidad), 0)) AS Inventario_Excedente\n",
        "    FROM Productos p\n",
        "    LEFT JOIN Detalle_Ventas d ON p.producto_id = d.producto_id\n",
        "    GROUP BY p.producto_id\n",
        "    HAVING Unidades_Vendidas < 50 AND Stock_Almacenado > 50\n",
        "    ORDER BY Stock_Almacenado DESC;\n",
        "'''\n",
        "df_over = pd.read_sql_query(query_overstock, conn)\n",
        "df_over"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "query_c"
      },
      "outputs": [],
      "source": [
        "# --- CONSULTA C: Rotación e Ingresos por Categoría ---\n",
        "# Decisión Directiva: Redistribución física de los almacenes optimizando pasillos rápidos.\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"[ANÁLISIS C] RENDIMIENTO Y ROTACIÓN POR CATEGORÍA\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "query_rotacion = '''\n",
        "    SELECT \n",
        "        c.nombre_categoria AS Categoria,\n",
        "        COUNT(DISTINCT v.venta_id) AS Transacciones,\n",
        "        SUM(d.cantidad) AS Unidades_Vendidas,\n",
        "        SUM(d.subtotal) AS Ingresos_Totales\n",
        "    FROM Detalle_Ventas d\n",
        "    JOIN Ventas v ON d.venta_id = v.venta_id\n",
        "    JOIN Productos p ON d.producto_id = p.producto_id\n",
        "    JOIN Categorias c ON p.categoria_id = c.categoria_id\n",
        "    GROUP BY c.nombre_categoria\n",
        "    ORDER BY Unidades_Vendidas DESC;\n",
        "'''\n",
        "df_rot = pd.read_sql_query(query_rotacion, conn)\n",
        "df_rot['Ingresos_Totales'] = df_rot['Ingresos_Totales'].apply(lambda x: f\"${x:,.0f} COP\")\n",
        "df_rot"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "query_d"
      },
      "outputs": [],
      "source": [
        "# --- CONSULTA D: Concentración Geográfica de Ventas ---\n",
        "# Decisión Directiva: Habilitar minihubs regionales secundarios y optimizar la logística local.\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"[ANÁLISIS D] CONCENTRACIÓN GEOGRÁFICA DE VENTAS\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "query_geografia = '''\n",
        "    SELECT \n",
        "        r.ciudad AS Ciudad,\n",
        "        r.pais AS Pais,\n",
        "        COUNT(DISTINCT v.venta_id) AS Cantidad_Pedidos,\n",
        "        SUM(v.total_venta) AS Facturacion_Total\n",
        "    FROM Ventas v\n",
        "    JOIN Regiones r ON v.region_id = r.region_id\n",
        "    GROUP BY r.ciudad\n",
        "    ORDER BY Facturacion_Total DESC;\n",
        "'''\n",
        "df_geo = pd.read_sql_query(query_geografia, conn)\n",
        "df_geo['Facturacion_Total'] = df_geo['Facturacion_Total'].apply(lambda x: f\"${x:,.0f} COP\")\n",
        "df_geo"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "cell_close"
      },
      "outputs": [],
      "source": [
        "# Cerrar conexion analitica\n",
        "conn.close()\n",
        "print(\"[INFO] Conexion a base de datos cerrada de forma segura.\")"
      ]
    }
  ]
